[Unit]
Description=GitHub Crawler Frontend Service
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/github_crawler/frontend
ExecStart=/usr/bin/npm run dev
Restart=always
RestartSec=10
StandardOutput=append:/home/admin/github_crawler/logs/frontend.log
StandardError=append:/home/admin/github_crawler/logs/frontend-error.log

# 环境变量
Environment=NODE_ENV=development

# 资源限制
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
